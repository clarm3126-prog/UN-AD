{
  "name": "un-ad",
  "version": "1.0.0",
  "description": "Review filtering pipeline with ingestion, queue worker, and web UI",
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "api:start": "node backend/api-server.js",
    "ingest:run": "node backend/ingestion-service.js --source=csv",
    "ingest:coupang": "node backend/ingestion-service.js --source=coupang",
    "ingest:all": "node backend/ingestion-service.js --source=all",
    "worker:run": "node worker/filter-worker.js",
    "seed:sample": "node scripts/seed-sample-data.js",
    "crawl:template": "node scripts/crawl-coupang-template.js",
    "smoke:check": "bash scripts/smoke_check.sh",
    "pipeline:run": "npm run ingest:run && npm run worker:run",
    "test": "echo \"No tests configured\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "openai": "^6.25.0",
    "xlsx": "^0.18.5"
  }
}
