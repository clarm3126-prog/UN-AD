# Ingestion source mode for Coupang adapter: mock-file | http
COUPANG_SOURCE_MODE=mock-file

# If mode=http, provide a URL template with placeholders.
# Example placeholders: {productId}, {vendorItemId}, {vendorId}
COUPANG_REVIEW_API_URL_TEMPLATE=

# Coupang API credentials (optional in mock mode)
COUPANG_ACCESS_KEY=
COUPANG_SECRET_KEY=
COUPANG_VENDOR_ID=

# Optional file overrides
COUPANG_PRODUCTS_FILE=data/source/products.csv
COUPANG_REVIEW_MOCK_FILE=data/source/coupang/mock-reviews.json
